# TripPlanner AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (Required for AI generation)
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API Key (Optional — simulated if blank)
# Get one at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Database URL (defaults to SQLite for local dev)
# For production PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./tripplanner.db

# JWT Secret Key — change this to a long random string in production!
SECRET_KEY=your-super-secret-key-change-in-production
