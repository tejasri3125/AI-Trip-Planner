# TripPlanner AI — Production Environment Variables
# This file is used by Vite during `npm run build`
# IMPORTANT: After deploying the backend on Render, replace the URL below
# with your actual Render backend URL, e.g.:
# VITE_API_URL=https://tripplanner-backend.onrender.com/api

VITE_API_URL=https://tripplanner-backend.onrender.com/api
